{
  "name": "lamonega.com.ar",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    "ghcr.io/devcontainers/features/hugo:1": {
      "extended": true,
      "version": "0.147.2"
    }
  },
  "postCreateCommand": "./.devcontainer/install-extensions.sh && git submodule update --init --recursive",
  "customizations": {
    "vscode": {
      "extensions": [
        "tamasfe.even-better-toml",
        "davidanson.vscode-markdownlint",
        "budparr.language-hugo-vscode"
      ],
      "settings": {
        "markdownlint.config": {
          "MD041": false
        }
      }
    }
  }
}
